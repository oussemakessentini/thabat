# Local development for journey-service. Copy to .env — do not commit .env.

SERVER_PORT=8082
SPRING_PROFILES_ACTIVE=local

# Must match Identity Service JWT_SECRET (at least 32 characters).
# IDEA/OS env JWT_SECRET overrides this file — avoid a truncated value there.
JWT_SECRET=thabat-local-dev-jwt-secret-change-me-32chars-min

DB_URL=jdbc:postgresql://localhost:5433/thabat_journey_db
DB_USERNAME=postgres
DB_PASSWORD=

EUREKA_SERVER_URL=http://localhost:8761/eureka/
