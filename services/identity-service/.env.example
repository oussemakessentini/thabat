# Local development environment for identity-service
# Copy to .env and fill in your values. Do not commit .env.

SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=local

# Required: at least 32 characters for HS256
JWT_SECRET=thabat-local-dev-jwt-secret-change-me-32chars-min
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Database (used when loading identity-service-local via Config Server)
DB_URL=jdbc:postgresql://localhost:5432/thabat_identity_db
DB_USERNAME=thabat
DB_PASSWORD=thabat

EUREKA_SERVER_URL=http://localhost:8761/eureka/
